{
  "manifest_version": 3,
  "name": "YouTube ミニプレーヤーボタン",
  "version": "1.0",
  "description": "YouTubeのコントロールバーにミニプレーヤーボタンを追加します",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
